{
  "build": {
    "beforeDevCommand": "pnpm -C frontend build && node scripts/desktop/prepare-sidecar.js --debug",
    "beforeBuildCommand": "pnpm -C frontend build && node scripts/desktop/prepare-sidecar.js --release",
    "devPath": "../frontend/dist",
    "distDir": "../frontend/dist"
  },
  "package": {
    "productName": "openteams",
    "version": "0.3.7"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "active": true,
      "targets": [
        "msi",
        "dmg",
        "appimage",
        "deb"
      ],
      "identifier": "com.openteams.desktop",
      "icon": [
        "icons/icon-square.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "windows": {
        "wix": {
          "bannerPath": "wix/assets/banner.bmp",
          "dialogImagePath": "wix/assets/dialog.bmp",
          "fragmentPaths": [
            "wix/fragments/openteams-directory.wxs"
          ]
        }
      },
      "deb": {
        "files": {
          "/DEBIAN/postrm": "debian/postrm",
          "/usr/share/icons/hicolor/scalable/apps/openteams.svg": "icons/logo_black.svg"
        }
      },
      "externalBin": [
        "bin/server",
        "bin/openteams-cli"
      ]
    },
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://updates.openteams.com/{{target}}/{{current_version}}"
      ],
      "pubkey": ""
    },
    "windows": [
      {
        "title": "openteams",
        "width": 1920,
        "height": 1080,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
